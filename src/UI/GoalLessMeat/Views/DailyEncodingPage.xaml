<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GoalLessMeat.Views.DailyEncodingPage"
             Title="Today">
    <StackLayout Spacing="15">
        <Label Text="What did you eat today?"
               SemanticProperties.HeadingLevel="Level1"
               FontSize="32"
               Margin="15"
               HorizontalOptions="Center"/>
        <VerticalStackLayout Spacing="15" HorizontalOptions="Center" VerticalOptions="Center">
            <Button Text="Vegan" ContentLayout="Left" Background="#2E7D32" TextColor="White" />
            <Button Text="Vegetarian" Background="#F9A825" TextColor="White" />
            <Button Text="Fish" Background="#008bff" TextColor="White" />
            <Button Text="Meat" Background="#C62828" TextColor="White"  />           
         </VerticalStackLayout>
       
    </StackLayout>
</ContentPage>
